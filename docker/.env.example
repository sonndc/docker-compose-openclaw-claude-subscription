# =============================================================
# OpenClaw Docker Compose - Environment Variables
# =============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Claude Proxy ---
PROXY_PORT=8080

# --- OpenClaw Gateway ---
GATEWAY_PORT=18789
DASHBOARD_TOKEN=generate-a-random-token-here

# --- Claude OAuth ---
# Path to ~/.claude on your HOST machine
CLAUDE_CONFIG_HOST=~/.claude

# --- OpenClaw Data ---
OPENCLAW_DATA=./data

# --- Shared Directory ---
# Files in this folder are accessible by both host and ClawBot
SHARED_DIR=./shared
